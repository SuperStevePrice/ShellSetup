#-------------------------------------------------------------------------------
# PROGRAM:
#   .profile
#
# PURPOSE:
#   ksh profile for Linux and macOS
#
# USAGE:
#   Invoked by the operating system at login.
#-------------------------------------------------------------------------------

#-------------------------------------------------------------------------------
# Locale (applies to all OS)
#-------------------------------------------------------------------------------
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8

#-------------------------------------------------------------------------------
# Primary prompt, aliases, and functions (applies to all OS)
#-------------------------------------------------------------------------------
. ~/bin/PS1.ksh      # PS1 prompt
. ~/.aliases          # aliases
. ~/.functions        # custom functions

# Hostname and default editor (applies to all OS)
export HOST=$(uname -n)
export FCEDIT=vi

#-------------------------------------------------------------------------------
# PATH Setup (applies to all OS)
#-------------------------------------------------------------------------------
# Base system utilities
PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# User and optional locations
PATH="$PATH:$HOME/bin:$HOME/anaconda3/bin:/opt/homebrew/bin:/opt/X11/bin:."

# Remove duplicates from PATH
export PATH=$(echo $PATH | awk -v RS=':' '!a[$0]++ {if (NR>1) printf(":"); printf("%s", $0)}')

#-------------------------------------------------------------------------------
# macOS-specific configuration (runs ONLY on Darwin/macOS)
#-------------------------------------------------------------------------------
if [ "$(uname)" = "Darwin" ]; then
    # ------------------------
    # Homebrew and Perl environment
    # ------------------------
    export PATH="/opt/homebrew/bin:$PATH"
    export PERL5LIB="/opt/homebrew/lib/perl5:/opt/homebrew/lib/perl5/site_perl"
    export PERL5LIB="$HOME/.cpanm/work/1728126447.24554/Tk-804.036/Tk.pm:$PERL5LIB"
    export PERL_LOCAL_LIB_ROOT="/opt/homebrew/lib/perl5"
    export PERL_MB_OPT="--install_base=/opt/homebrew/lib/perl5"
    export PERL_MM_OPT="INSTALL_BASE=/opt/homebrew/lib/perl5"
    eval "$(perl -I$HOME/perl5/lib/perl5 -Mlocal::lib=$HOME/perl5)"

    # Perlbrew environment
    export PERLBREW_HOME="$HOME/perl5/perlbrew"
    export PERLBREW_ROOT="$HOME/perl5/perlbrew"
    export PATH="$HOME/perl5/perlbrew/bin:$PATH"
    if [[ -d "$PERLBREW_ROOT/perls" ]]; then
        export PATH="$PERLBREW_ROOT/perls/perl-5.38/bin:$PATH"
    fi  

    # ------------------------
    # Python paths
    # ------------------------
    PYTHONPATH="/Users/steve/anaconda3/lib/python3.11:/site-packages/tkmacosx:$PYTHONPATH"
    export PYTHONPATH
    export PYTHONPATH=$(echo $PYTHONPATH | awk -v RS=':' '!a[$0]++ {if (NR>1) printf(":"); printf("%s", $0)}')

    # ------------------------
    # Tk and X11 compilation flags
    # ------------------------
    export CFLAGS="-O2 -g -D_FILE_OFFSET_BITS=64 -arch arm64 -I/opt/homebrew/opt/tcl-tk/include -I/opt/homebrew/opt/libx11/include -I/opt/homebrew/opt/jpeg/include -I/opt/X11/include"
    export LDFLAGS="-L/opt/homebrew/opt/tcl-tk/lib -L/opt/homebrew/opt/libx11/lib -L/opt/homebrew/opt/jpeg/lib -L/opt/X11/lib -L/opt/homebrew/opt/zlib/lib -arch arm64 -L/opt/homebrew/opt/gdbm/lib"
    export CPPFLAGS="-I/opt/homebrew/opt/zlib/include -I/opt/homebrew/opt/gdbm/include"
    export CC=clang
    export CXX=clang++

    # Suppress Python Tk deprecation warnings
    export TK_SILENCE_DEPRECATION=1
    export TCL_INCLUDE_PATH="/opt/homebrew/opt/tcl-tk/include"
    export TK_INCLUDE_PATH="/opt/homebrew/opt/tcl-tk/include"
    export TCL_LIB_PATH="/opt/homebrew/opt/tcl-tk/lib"
    export TK_LIB_PATH="/opt/homebrew/opt/tcl-tk/lib"

    # Brew shell environment
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

#-------------------------------------------------------------------------------
# Conda / Anaconda initialization (applies to all OS if present)
#-------------------------------------------------------------------------------
if [ -x "$HOME/anaconda3/bin/conda" ]; then
    __conda_setup=$("$HOME/anaconda3/bin/conda" 'shell.ksh' 'hook' 2> /dev/null)
    if [ $? -eq 0 ]; then
        eval "$__conda_setup"
    else
        if [ -f "$HOME/anaconda3/etc/profile.d/conda.sh" ]; then
            . "$HOME/anaconda3/etc/profile.d/conda.sh"
        else
            export PATH="$HOME/anaconda3/bin:$PATH"
        fi
    fi
    unset __conda_setup
fi

#-------------------------------------------------------------------------------
# Terminal settings (applies to all OS)
#-------------------------------------------------------------------------------
export TERM=vt100

#-------------------------------------------------------------------------------
# Command line editing (applies to all OS)
#-------------------------------------------------------------------------------
set -o vi

#-------------------------------------------------------------------------------
# End of profile
#-------------------------------------------------------------------------------

